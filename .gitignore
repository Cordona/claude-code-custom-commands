# =============================================================================
# Claude Code Custom Commands Repository - .gitignore
# =============================================================================
# Comprehensive gitignore file following Anthropic's official recommendations
# and best practices for documentation repositories.

# =============================================================================
# Claude Code Configuration Files
# =============================================================================

# Local settings (automatically handled by Claude Code)
# These are personal preferences that shouldn't be shared
.claude/settings.local.json

# Personal CLAUDE.md file (if using CLAUDE.local.md pattern)
# Uncomment if you create personal instruction files
# CLAUDE.local.md

# Claude Code session files (if any are generated)
.claude/sessions/

# Generated artifacts from custom commands
# These files are generated by commands and should not be tracked in version control
.claude/artifacts/
.claude/cache/
.claude/logs/

# =============================================================================
# Documentation & Development Files
# =============================================================================

# Temporary documentation files
*.tmp
*.temp
*~
.#*

# Editor backup files
*.bak
*.swp
*.swo

# Draft files and work-in-progress documentation
drafts/
*.draft.md
*.wip.md

# =============================================================================
# System Files
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db:encryptable
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================================================================
# IDE and Editor Files
# =============================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.ipr
*.iws

# Vim
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# Development and Build Files
# =============================================================================

# Node.js (if any tooling is added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
.npm
.eslintcache

# Python (if any tooling is added)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# =============================================================================
# Documentation Generation Tools
# =============================================================================

# Generated documentation
_site/
.jekyll-cache/
.jekyll-metadata

# GitBook
_book/
.grunt

# Docusaurus
.docusaurus/

# MkDocs
site/

# =============================================================================
# Change Log and Backup Files
# =============================================================================

# Temporary changelog files
change-log/**/*.tmp
change-log/**/*.backup

# Documentation synchronization backups
/tmp/doc-sync-backup-*
.backup/

# Temporary command testing files
.command-test-*
test-command-*

# =============================================================================
# Git and Version Control
# =============================================================================

# Git patch files
*.patch
*.diff

# =============================================================================
# Sensitive Information
# =============================================================================

# Environment variables and secrets
.env
.env.local
.env.*.local

# Personal notes and TODO files (that shouldn't be shared)
personal-notes.md
todo.md
scratch.md
tasks.txt

# API keys and configuration (if any)
secrets/
*.key
*.pem
*.p12
*.pfx

# =============================================================================
# Logs and Debug Files
# =============================================================================

# General log files
*.log
logs/

# Debug files
debug.log
error.log

# =============================================================================
# Compression and Archive Files
# =============================================================================

# Archives
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# =============================================================================
# AI and LLM Related Files
# =============================================================================

# Model files (if any are downloaded)
*.model
*.gguf
*.bin

# Training data or large datasets
data/
datasets/
*.jsonl

# =============================================================================
# Custom Project Specific Ignores
# =============================================================================

# Command testing artifacts
.command-validation/
test-runs/

# Documentation generation artifacts
.doc-generation/
.changelog-temp/

# Personal command experiments
experiments/
playground/

# Team collaboration drafts (use different naming for shared drafts)
*.personal.md
*.private.md

# =============================================================================
# Comments and Documentation for .gitignore
# =============================================================================

# This .gitignore file is designed for the Claude Code Custom Commands repository
# and follows Anthropic's official recommendations for Claude Code projects.
#
# Key principles:
# 1. Keep team-shared configurations in git (CLAUDE.md, .claude/settings.json)
# 2. Ignore personal preferences (.claude/settings.local.json)
# 3. Ignore system-generated and temporary files
# 4. Ignore sensitive information and personal notes
#
# For more information, see:
# - https://docs.anthropic.com/en/docs/claude-code/settings
# - https://docs.anthropic.com/en/docs/claude-code/memory
# - DISCLAIMER.md (for AI generation transparency)